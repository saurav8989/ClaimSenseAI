      { "code": "TEST-GLU-RBS", "name": "Random Blood Sugar (RBS)", "mandatory": true },
      { "code": "TEST-GLU-HBA1C", "name": "Glycated Hemoglobin (HbA1c)", "mandatory": true },
      { "code": "TEST-UA-PROT", "name": "Urine Protein Test", "mandatory": false },
