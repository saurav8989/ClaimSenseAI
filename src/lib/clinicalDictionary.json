      },
      {
        "id": "RULE-DEN-4",
        "name": "Supportive Therapy & Hospital Referral",
        "type": "referral_check",
        "severity": "MAJOR",
        "penalty": 20,
        "description": "Dengue claims must document supportive care (Paracetamol/ORS) and hospital referral."
      }
    ]
  },
