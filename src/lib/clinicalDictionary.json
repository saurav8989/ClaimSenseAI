      { "code": "TEST-RENAL", "name": "Serum Urea & Creatinine", "mandatory": false },
      { "code": "TEST-UA", "name": "Urine Analysis", "mandatory": false },
      { "code": "TEST-LIPID", "name": "Lipid Profile", "mandatory": false }
    ],
    "medications": [
      { "code": "MED-AML-5", "name": "Amlodipine 5mg", "firstLine": true },
      { "code": "MED-LOS-25", "name": "Losartan 25mg", "firstLine": true },
      { "code": "MED-AML-10", "name": "Amlodipine 10mg", "emergency": true },
      { "code": "MED-LOS-50", "name": "Losartan 50mg", "emergency": true }
    ],
    "procedures": [],
    "rules": [
      {
        "id": "RULE-HTN-1",
        "name": "Hypertension BP Check",
        "type": "test_required",
        "severity": "CRITICAL",
        "penalty": 40,
        "description": "Prescribing anti-hypertensive medication requires a recorded Blood Pressure check."
      },
      {
        "id": "RULE-HTN-2",
        "name": "Hypertension Treatment Match",
        "type": "medication_match",
        "severity": "MAJOR",
        "penalty": 20,
        "description": "Primary diagnosis Hypertension requires starting first-line monotherapy (Amlodipine 5mg or Losartan 25mg)."
      },
      {
        "id": "RULE-HTN-3",
        "name": "Hypertensive Crisis Emergency Protocol",
        "type": "referral_check",
        "severity": "MAJOR",
        "penalty": 35,
        "description": "Severe blood pressure (>=180/120) or target organ damage requires stat Amlodipine 10mg / Losartan 50mg and immediate referral."
      }
    ]
  },
