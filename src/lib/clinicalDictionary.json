{
  "1F4": {
    "id": "malaria",
    "name": "Malaria",
    "icd11Prefixes": ["1F4", "KA64.2"],
    "synonyms": [
      "fever",
      "chills",
      "shivering",
      "headache",
      "joint pain",
      "malaria",
      "mosquito",
      "plasmodium",
      "falciparum",
      "vivax",
      "congenital malaria"
    ],
    "diagnosticTests": [
      { "code": "TEST-MAL-RDT", "name": "Malaria Rapid Diagnostic Test (RDT)", "mandatory": true },
      { "code": "TEST-MAL-MIC", "name": "Malaria Blood Smear / Microscopy", "mandatory": true }
    ],
    "medications": [
      { "code": "MED-CQ-150", "name": "Chloroquine 150mg", "firstLine": true },
      { "code": "MED-PQ-7.5", "name": "Primaquine 7.5mg", "firstLine": true },
      { "code": "MED-PQ-2.5", "name": "Primaquine 2.5mg", "firstLine": true },
      { "code": "MED-AL-ACT", "name": "Artemether-Lumefantrine (ACT)", "firstLine": true },
      { "code": "MED-DHAP", "name": "Dihydroartemisinin-Piperaquine (DHAP)", "secondLine": true },
      { "code": "MED-ART-INJ", "name": "Inj Artesunate (IV/IM)", "preReferral": true }
    ],
    "procedures": [],
    "rules": [
      {
        "id": "RULE-MAL-1",
        "name": "Malaria Diagnostic Check",
        "type": "test_required",
        "severity": "CRITICAL",
        "penalty": 40,
        "description": "Prescribing antimalarials requires a prior diagnostic verification (RDT or Microscopy)."
      },
      {
        "id": "RULE-MAL-2",
        "name": "Malaria Treatment Alignment",
        "type": "medication_match",
        "severity": "MAJOR",
        "penalty": 30,
        "description": "Malaria diagnosis must be treated with approved first-line antimalarials (Chloroquine/Primaquine or Artemether-Lumefantrine)."
      },
      {
        "id": "RULE-MAL-3",
        "name": "Primaquine Contraindication Check",
        "type": "contraindication_check",
        "severity": "CRITICAL",
        "penalty": 50,
        "description": "Primaquine is contraindicated during pregnancy, lactation (for infants < 6 months), or in infants under 6 months."
      },
      {
        "id": "RULE-MAL-4",
        "name": "Severe Malaria Referral Required",
        "type": "referral_check",
        "severity": "CRITICAL",
        "penalty": 40,
        "description": "Severe malaria clinical features require pre-referral Inj Artesunate and immediate referral."
      },
      {
        "id": "RULE-MAL-5",
        "name": "Second-line (DHAP) Restriction",
        "type": "treatment_sequence",
        "severity": "MAJOR",
        "penalty": 25,
        "description": "DHAP second-line therapy requires documented drug failure or intolerance, and immediate referral."
      }
    ]
  },
  "BA00": {
