      { "code": "TEST-CBC", "name": "Complete Blood Count", "mandatory": true },
      { "code": "TEST-LFT", "name": "Liver Function Test", "mandatory": false }
    ],
    "medications": [
      { "code": "MED-PAR-500", "name": "Paracetamol 500mg", "firstLine": true },
      { "code": "MED-ORS", "name": "Oral Rehydration Salts (ORS)", "firstLine": true },
